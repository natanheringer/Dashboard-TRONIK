# ========================================
# CONFIGURAÇÕES DE SEGURANÇA - Dashboard-TRONIK
# ========================================
# Copie este arquivo para .env na raiz do projeto
# NUNCA commite o arquivo .env no Git!
#
# IMPORTANTE — Em produção configure:
#   - SECRET_KEY: 32+ caracteres aleatorios (veja instrução abaixo)
#   - FLASK_ENV: "production"
#   - SESSION_COOKIE_SECURE: true (HTTPS obrigatório)
#   - CORS_ORIGINS: domínios específicos (não "*")
#   - DATABASE_URL: PostgreSQL externo (não SQLite)
#   - RATELIMIT_STORAGE_URL: Redis (não memory://)
#   - Todas MAIL_* variáveis para notificações
#   - Todas NIK_* e API_KEY* se usar assistente ou integração
#
# CSRF / SEGURANÇA DE SESSÃO:
#   - SESSION_COOKIE_SECURE=true (HTTPS)
#   - SESSION_COOKIE_HTTPONLY=true (padrão, sem acesso JS)
#   - SESSION_COOKIE_SAMESITE: "Lax" em dev; app força "Strict" quando FLASK_ENV=production
#   - FLASK_LOGIN_SESSION_PROTECTION="strong" (em produção)
#
# RATE LIMITING:
#   - RATELIMIT_ENABLED=true (padrão)
#   - RATELIMIT_STORAGE_URL=redis://[host]:[port]/[db] em produção
#   - memory:// apenas para single-process dev

# ========================================
# CHAVE SECRETA - CRÍTICA
# ========================================
# Chave secreta para sessões, CSRF tokens e autenticação
# GERE UMA NOVA: python -c "import secrets; print(secrets.token_hex(32))"
# MÍNIMO 32 caracteres; production deve ter 64+ (256 bits)
SECRET_KEY="troque-por-uma-chave-forte-e-aleatoria"

# Ambiente: development, production
FLASK_ENV=development

# Banner modal convidando para /preview (true/false). Padrão: false (produção).
PREVIEW_DEMO_BANNER=false

# Badge fixo "PREVIEW v2" no canto da UI v2 (true/false). Padrão: false (produção).
PREVIEW_SHOW_BADGE=false

# Configuração do banco de dados
# DATABASE_URL deve ser a MESMA instância para:
#   - Flask (app.py / gunicorn)
#   - Jobs CLI (python -m jobs.prospeccao ...)
# Em deploy (Render/Railway), aponte Flask e workers/cron para o mesmo Postgres.
DATABASE_URL="sqlite:///tronik.db"

TRONIK_SEDE_LAT=
TRONIK_SEDE_LNG=
TRONIK_SEDE_LABEL=Sede Tronik

# CORS - Origens permitidas (separe por vírgula se mais de um)
# Em desenvolvimento, pode usar "*" mas em produção use domínios específicos
CORS_ORIGINS="http://localhost:5000,http://127.0.0.1:5000"

# Rate Limiting
RATELIMIT_ENABLED=true
# memory:// e apenas desenvolvimento (um processo). Em producao com varios workers:
RATELIMIT_STORAGE_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URL=memory://

# Observabilidade (Sentry) — opcional; pip install 'sentry-sdk[flask]>=2.0'
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Telemetria (ESP32 -> POST /api/sensor/telemetria) ---
# Opcional: um unico segredo para todos os dispositivos durante migracao (desligue depois).
# TELEMETRY_SHARED_SECRET=
# Em desenvolvimento, permite POST sem api_token no sensor se true:
TELEMETRIA_ALLOW_NO_TOKEN=true

# Configurações de segurança
SESSION_COOKIE_SECURE=false  # true em produção com HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE="Lax"

# Configurações de debug (apenas desenvolvimento)
DEBUG=false

# Configurações de logging
LOG_LEVEL=INFO

# ========================================
# USUÁRIO ADMINISTRADOR + LOGIN FIXO EM DESENVOLVIMENTO
# ========================================
#
# Produção ou ambientes não-dev: defina ADMIN_* para criar o primeiro admin se ainda não existir.
#
# Em FLASK_ENV=development, se você NÃO definir nenhuma variável ADMIN_*, o primeiro admin
# é criado automaticamente com os valores DEV_* abaixo (usuário dev, senha fixa para testes locais).
#
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Credenciais de desenvolvimento (usuário extra "dev" sempre que possível — ver código)
DEV_USERNAME=dev
DEV_EMAIL=dev@localhost.internal
DEV_PASSWORD=DevTronik!local

# Para repor a senha do utilizador DEV_USERNAME quando já existir na base:
# DEV_SYNC_PASSWORD=true

# Para desativar qualquer uso automático de DEV_* (primeiro admin sem ADMIN_* ou utilizador dev):
# DISABLE_DEV_CREDENTIALS=true

# IMPORTANTE: ADMIN_PASSWORD deve ter pelo menos 8 caracteres quando configurado explicitamente.

# ========================================
# NIK (assistente operacional)
# ========================================
# NIK_ENABLED=true
# NIK_AGENT_PLANNER=heuristic|llm|auto
# heuristic = regras locais (_planejar_ferramentas)
# llm = planejador LLM; se falhar parse/API, cai no heurístico
# auto = tenta LLM e depois heurístico (mesmo fallback que llm)
# NIK_AGENT_LOOP=false
# true = loop nativo tool-calling (OpenAI tools API) em vez de plano único
# NIK_MODELO_RESUMO=llama-3.1-8b-instant
# Resumo automático de threads longas (>12 mensagens)
# NIK_MULTIMODAL_ENABLED=false
# true = botão "Anexar imagem" e POST /api/nik/ops/analisar-imagem

# Configurações de email (para notificações)
# Descomente e configure para habilitar notificações por email
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@tronik.com

# Configurações de agendamento automático
AGENDAMENTO_ENABLED=false
# Habilita processamento automático de alertas
# true = ativado, false = desativado

AGENDAMENTO_INTERVALO_MINUTOS=60
# Intervalo em minutos para processar alertas automaticamente
# Padrão: 60 minutos (1 hora)
# Mínimo recomendado: 15 minutos

# ========================================
# PIPELINE ML PROSPECÇÃO REE (Sócrates)
# ========================================
# Requer AGENDAMENTO_ENABLED=true para o scheduler APScheduler estar ativo.
PROSPECCAO_PIPELINE_ENABLED=false
# true = agenda ingest→normalize→link-crm→build-features→train→score (publicação via score-candidates)

PROSPECCAO_PIPELINE_INTERVAL_HOURS=168
# Intervalo entre execuções (padrão 168 = semanal)

PROSPECCAO_PIPELINE_VERSION=prospeccao-ree-v3.2
# Versão do schema/pipeline passada a build-features e train-ranker

PROSPECCAO_PIPELINE_USE_INTERNAL_LABELS=true
# Labels operacionais (parceiro/coleta/contrato) em build-features

PROSPECCAO_PIPELINE_SKIP_INGEST=false
# true = pula harvest no job agendado (útil se ingest roda em cron separado)

PROSPECCAO_PIPELINE_SKIP_NORMALIZE=false
# true = pula normalize no job agendado

PROSPECCAO_PIPELINE_INGEST_STEPS=ibge,geoportal,ckan_meta,pncp
# Passos do harvest quando ingest está habilitado

PROSPECCAO_PIPELINE_USE_PS1=false
# true (Windows): usa run_pipeline.ps1 com -SkipFetch -SkipCnefe -SkipReceita

PROSPECCAO_PIPELINE_BUILD_LIMIT=
# Limite opcional de empresas em build-features (smoke test, ex.: 100)

PROSPECCAO_PIPELINE_STEP_TIMEOUT_S=7200
# Timeout por passo CLI em segundos (padrão 2h)

PROSPECCAO_BUILD_ENRICHMENT=false
# true = executa build-enrichment antes de build-features no pipeline agendado

# Parquets de enriquecimento territorial (Sócrates) — gerados por: python -m jobs.prospeccao build-enrichment
TRONIK_OSM_POI_PARQUET=data/ml/staging/osm_poi_ree.parquet
TRONIK_INEP_CENSO_PARQUET=data/ml/staging/inep_censo_ra.parquet
TRONIK_CNES_PARQUET=data/ml/staging/cnes_mun.parquet
TRONIK_ENRICHMENT_RADIUS_KM=3.0
# Raio (km) para contagem de POIs OSM e fallback espacial INEP/CNES

# Fontes brutas (download via ingest: geofabrik, inep, cnes)
TRONIK_INEP_CENSO_ESCOLAR_CSV_URL=
# URL do CSV INEP; após `inep`, o ficheiro fica em data/raw/prospeccao/inep/
TRONIK_CNES_BASE_ZIP_URL=
# URL do ZIP CNES mensal DATASUS; após `cnes`, fica em data/raw/prospeccao/cnes/
TRONIK_GEOFABRIK_PBF_URL=https://download.geofabrik.de/south-america/brazil/centro-oeste-latest.osm.pbf

# Variáveis de enriquecimento territorial (paths locais)
TRONIK_OSM_SOURCE_DIR=
# Opcional: diretório de cache para dados OSM brutos (sobrescreve download Geofabrik)
TRONIK_INEP_SOURCE_DIR=
# Opcional: diretório de cache para dados INEP CENSO Escolar brutos
TRONIK_CNES_SOURCE_DIR=
# Opcional: diretório de cache para dados CNES brutos

# ========================================
# NIK (ASSISTENTE OPERACIONAL) - CONFIGURAÇÕES GERAIS
# ========================================
NIK_ENABLED=false
# true = ativa o assistente Nik em toda a aplicação (chat, landing, análises, webs)

NIK_AGENT_PLANNER=heuristic
# Modo de planejamento da Nik:
#   heuristic = regras locais (_planejar_ferramentas)
#   llm = planejador via LLM; fallback para heurístico se falhar
#   auto = tenta LLM e depois heurístico
NIK_AGENT_LOOP=false
# true = loop nativo tool-calling (OpenAI tools API) em vez de plano único

NIK_MULTIMODAL_ENABLED=false
# true = ativa análise de imagens (POST /api/nik/ops/analisar-imagem)
NIK_MODELOS_VISAO=
# Lista de modelos suportados para visão (comma-separated, ex: "gemma-3-27b,mixtral-8x22b")
# Deixe vazio para usar padrão: Gemma 3 27B

# ========================================
# NIK - MODELOS PADRÃO
# ========================================
NIK_MODELO_FALLBACK=llama-3.1-8b-instant
# OBRIGATÓRIA: modelo pequeno rápido para fallback de qualquer contexto

NIK_MODELO_OPS=google/gemma-3-27b-it
# Modelo principal para operações (análises, resumos, sínteses)
# Suporta multimodal (imagens) — Gemma 3 27B ou configurável

NIK_MODELO_CHAT=llama-3.1-8b-instant
# Modelo para conversas (threads, continuidade de contexto)

NIK_MODELO_ANALYTICS=
# Modelo para análises operacionais complexas. Se vazio, usa NIK_MODELO_OPS

NIK_MODELO_LANDING=
# Modelo para geração de conteúdo landing (fala_nik, fatos, impacto). Se vazio, usa chat padrão.

NIK_MODELO_RELATORIO=
# Modelo para narrativas de relatórios. Se vazio, usa modelo pequeno (fallback).

NIK_MODELO_WEB=
# Modelo para síntese de buscas web. Se vazio, usa chat padrão.

NIK_MODELO_WEB_SAFE=
# Modelo seguro (menor TPD) para buscas web fallback. Se vazio, usa fallback.

NIK_MODELO_RESUMO=gemma-3-1b-it
# Modelo leve para resumo automático de threads longas (>12 mensagens)

NIK_MODELO_LONG_CONTEXT=
# Modelo com contexto longo (128k+) para análises recursivas. Deixe vazio para desabilitar.

NIK_MODELO_WEB_WRITER=
# Modelo para sintetizar buscas web em narrativa. Se vazio, usa analítica ou fallback.

NIK_MODELO_CHAT_NVIDIA=nvidia/nemotron-3-super-120b-a12b
# Modelo Nemotron (NVIDIA NIM) para chat em NVIDIA Integrate

NIK_MODELO_LANDING_NVIDIA=mistralai/mistral-nemotron
# Modelo Nemotron (NVIDIA NIM) para landing em NVIDIA Integrate

# ========================================
# NIK - PROVEDORES DE API
# ========================================
NVIDIA_API_KEY=
# OBRIGATÓRIA: chave para NVIDIA Integrate / NIM (https://integrate.api.nvidia.com/v1)
# Obtém em: https://build.nvidia.com/

NIK_API_BASE_URL=https://integrate.api.nvidia.com/v1
# URL base do provedor principal (NVIDIA Integrate padrão; pode usar Groq, Together, etc.)

NIK_NVIDIA_INTEGRATE_API_KEY=
# OPCIONAL: chave alternativa para NVIDIA Integrate (fallback se NVIDIA_API_KEY falhar)
# Se não definida, usa NVIDIA_API_KEY

NIK_NVIDIA_INTEGRATE_BASE_URL=https://integrate.api.nvidia.com/v1
# URL alternativa de NVIDIA Integrate se não usar o padrão

NIK_NVAPI_KEY=
# OPCIONAL: alias alternativo para NIK_NVIDIA_INTEGRATE_API_KEY

# ========================================
# NIK - PROVEDOR FALLBACK (opcional)
# ========================================
NIK_PROVIDER_FALLBACK_ENABLED=true
# true = tenta provedor fallback (ex. Groq) se principal falhar com rate limit

NIK_API_FALLBACK_BASE_URL=
# OPCIONAL: URL de API fallback (ex: https://api.groq.com/openai/v1 para Groq)

NIK_API_FALLBACK_KEY=
# OPCIONAL: chave de API fallback (ex: chave Groq gsk-...)

NIK_NVIDIA_MODELO=
# Modelo alternativo para provedor NVIDIA fallback. Se vazio, usa NIK_MODELO_FALLBACK

NIK_NVIDIA_MODELO_DEFAULT=
# Alias para NIK_NVIDIA_MODELO

# ========================================
# NIK - COMPORTAMENTO DE RATE LIMIT
# ========================================
NIK_RATE_LIMIT_COOLDOWN_SECONDS=900
# Segundos de espera após rate limit (padrão 15 min)

NIK_TRY_FALLBACK_ON_RATE_LIMIT=true
# true = tenta provedor fallback se principal sofrer rate limit 429/TPD

NIK_ALLOW_LLAMA_70B=false
# false = bloqueia Llama 3.3 70B na Groq (TPD agressivo) e compound-mini
# true = permite (útil apenas se tendo TPD alto)

# ========================================
# NIK - CONFIGURAÇÕES DE REDE
# ========================================
NIK_HTTP_TIMEOUT_S=120
# Timeout de requisição HTTP em segundos (mín 15, padrão 120)

NIK_NETWORK_RETRY_COUNT=2
# Número de retentativas em erro de rede (mín 0, máx 5)

NIK_NETWORK_RETRY_BACKOFF_MS=400
# Milissegundos de backoff exponencial (0.05s..8s com jitter)

NIK_PROVIDER_MAX_RETRIES=0
# Retentativas nativas do SDK OpenAI (padrão 0 = retry customizado)

# ========================================
# NIK - NEMOTRON (NVIDIA) - REASONING
# ========================================
NIK_NEMOTRON_REASONING_DISABLED=true
# false = ativa reasoning/thinking em Nemotron (aumento de latência e tokens)

NIK_NEMOTRON_THINKING=false
# true = ativa enable_thinking em Nemotron (requer NVIDIA NIM)

NIK_NEMOTRON_REASONING_BUDGET=4096
# Tokens alocados para reasoning interno (só se THINKING=true)

NIK_NEMOTRON_EXTRA_BODY=
# JSON adicional para requisição Nemotron (ex: {"reasoning_budget": 6000})

# ========================================
# NIK - LANDING PAGE (PRÉ-GERAÇÃO)
# ========================================
NIK_LANDING_USE_NVIDIA=true
# true = usa NVIDIA Integrate para landing (Nemotron); false usa primário

NIK_PRE_GERACAO_ENABLED=false
# true = agenda pré-geração de blocos landing (landing service cache)

NIK_PRE_GERACAO_INTERVALO_MIN=60
# Intervalo em minutos entre pre-gerações (padrão 60 min)

# ========================================
# NIK - CHAT (Thread Memory & Tool Calling)
# ========================================
NIK_CHAT_USE_NVIDIA=false
# true = força uso de NVIDIA NIM para chat (Nemotron com tool_calls)

NIK_MAX_TOKENS_OPS=512
# Tokens máximos por resposta operacional

NIK_TEMPERATURE_OPS=0.3
# Temperatura (criatividade) para análises operacionais (0.0 — 1.0)

NIK_TEMPERATURE_LANDING=0.7
# Temperatura para geração landing (mais criativa)

NIK_TEMPERATURE_DOCUMENTO=0.2
# Temperatura para análise de documentos (mais determinística)

NIK_TEMPERATURE_WEB_SYNTH=0.1
# Temperatura para síntese de web (factual, baixa criatividade)

NIK_TEMPERATURE_WEB_RELATORIO=0.45
# Temperatura para relatórios web (equilíbrio)

# ========================================
# NIK - BUSCA WEB (Nik Web Tools)
# ========================================
NIK_WEB_PROVIDER=serper
# Provedor de busca: "serper" (padrão), "google_search", "tavily", "bing", "mojeek"

NIK_WEB_API_KEY=
# Chave da API de busca configurada (ex: Serper, Google Custom Search, etc.)

NIK_WEB_ALLOWED_DOMAINS=
# Comma-separated whitelist de domínios permitidos para scraping (ex: "wikipedia.org,portal.tcu.gov.br")
# Se vazio, permite qualquer domínio

NIK_WEB_DISABLE_COMPOUND=true
# true = bloqueia roteamento para Compound (Groq) em buscas web

NIK_WEB_MAX_RESULTS=5
# Máximo de resultados de busca retornados (1..10)

NIK_WEB_RATE_LIMIT_PER_MIN=20
# Limite de requisições web por minuto

NIK_WEB_TIMEOUT_MS=8000
# Timeout de scraping de página em milissegundos

NIK_WEB_NETWORK_RETRIES=2
# Retentativas de rede para scraping (0..4)

NIK_WEB_CACHE_TTL=900
# TTL de cache de resultados web em segundos (padrão 15 min)

# ========================================
# NARRATIVA ML (Groq/Gemini/Ollama)
# ========================================
GROQ_API_BASE=https://api.groq.com/openai/v1
# URL base da API Groq (openai-compatible)

GROQ_API_KEY=
# OPCIONAL: chave Groq (gsk-...) para narrativas ML se NVIDIA_API_KEY não estiver disponível

GROQ_MODEL=llama-3.1-8b-instant
# Modelo Groq para narrativas (fallback)

GEMINI_API_KEY=
# OPCIONAL: chave Google Gemini para narrativas alternativas

GEMINI_MODEL=gemini-2.0-flash
# Modelo Google Gemini (se GEMINI_API_KEY configurada)

OLLAMA_HOST=http://localhost:11434
# URL do servidor Ollama local (se usar Ollama em vez de API cloud)

OLLAMA_MODEL=deepseek-r1:8b
# Modelo Ollama executado localmente

LLM_TIMEOUT=60
# Timeout geral para chamadas LLM em segundos

# ========================================
# ML - MACHINE LEARNING (Predição e Score)
# ========================================
ML_PREDICAO_ENABLED=true
# true = habilita recálculo automático de predições de enchimento (2x/dia, 12h)

ML_SCORE_ENABLED=true
# true = habilita recálculo automático de TRONIK Score (1x/dia, 24h)

TRONIK_SCORE_PESOS=
# JSON com pesos customizados para TRONIK Score (ex: {"distancia": 0.3, "frequencia": 0.7})
# Se vazio, usa pesos padrão

# ========================================
# PREVIEW / DEMO MODE
# ========================================
PREVIEW_PUBLIC=false
# OBRIGATÓRIA em produção = false
# true = desabilita login em /preview (NÃO USE EM PRODUÇÃO)

# ========================================
# DEBUG E LOGGING
# ========================================
DEBUG=false
# OBRIGATÓRIA em produção = false
# true = modo debug do Flask (dev apenas)

LOG_LEVEL=INFO
# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FILE=
# OPCIONAL: caminho de arquivo de log (ex: /var/log/tronik/app.log)
# Se vazio, loga só em stderr

# ========================================
# OBSERVABILIDADE (Sentry)
# ========================================
SENTRY_DSN=
# OPCIONAL: URL do Sentry para erro tracking
# Exemplo: https://examplePublicKey@o0.ingest.sentry.io/0

SENTRY_TRACES_SAMPLE_RATE=0.1
# Taxa de amostragem de traces (0.0..1.0)

# ========================================
# FLASK-LOGIN (Sessão e Proteção)
# ========================================
FLASK_LOGIN_SESSION_PROTECTION=basic
# Nível de proteção de sessão:
#   false/0/no/none = desativado
#   basic = valida IP/User-Agent (dev-friendly, permite LAN+VPN)
#   strong = mais restritivo (produção), invalida em mudança IP/UA
# Em FLASK_ENV=production padrão é "strong"

# ========================================
# TELEMETRIA (Sensores ESP32 / IoT)
# ========================================
TELEMETRY_SHARED_SECRET=
# OPCIONAL: segredo compartilhado para migração de tokens
# Permite POST em /api/sensor/telemetria sem api_token individual (use temporariamente)

TELEMETRIA_ALLOW_NO_TOKEN=false
# OBRIGATÓRIA em produção = false
# true = permite POST telemetria sem api_token (apenas dev/migração)

# ========================================
# CHECKLIST DE SEGURANÇA PARA PRODUÇÃO
# ========================================
# [ ] SECRET_KEY: 32+ caracteres aleatórios, diferente de desenvolvimento
# [ ] FLASK_ENV: "production"
# [ ] DATABASE_URL: PostgreSQL externo com SSL (não SQLite)
# [ ] RATELIMIT_STORAGE_URL: Redis dedicado (não memory://)
# [ ] SESSION_COOKIE_SECURE: true (requer HTTPS)
# [ ] SESSION_COOKIE_SAMESITE: Strict em prod (automático via app.py; dev usa Lax)
# [ ] CORS_ORIGINS: apenas domínios específicos necessários (não "*")
# [ ] FLASK_LOGIN_SESSION_PROTECTION: "strong"
# [ ] ADMIN_USERNAME, ADMIN_EMAIL, ADMIN_PASSWORD: configurados explicitamente
# [ ] DISABLE_DEV_CREDENTIALS: true (desativa usuário dev automático)
# [ ] PREVIEW_PUBLIC: false
# [ ] PREVIEW_DEMO_BANNER: false
# [ ] PREVIEW_SHOW_BADGE: false
# [ ] TELEMETRIA_ALLOW_NO_TOKEN: false
# [ ] DEBUG: false
# [ ] LOG_LEVEL: "WARNING" ou "ERROR"
# [ ] SENTRY_DSN: configurado para monitoramento de erros
# [ ] NVIDIA_API_KEY (ou equivalente para NIK): definida e não exposta
# [ ] Todas as MAIL_* variáveis: configuradas para notificações
# [ ] .env nunca commitado no Git (verificar .gitignore)
# [ ] HTTPS ativado na reverse proxy/load balancer
# [ ] WAF/rate limiting extra se exposto na Internet
# [ ] Audit logging ativado (LOG_FILE ou Sentry)
