# ========================================
# CONFIGURAÇÕES DE SEGURANÇA - Dashboard-TRONIK
# ========================================
# Copie este arquivo para .env na raiz do projeto
# NUNCA commite o arquivo .env no Git!

# Chave secreta para sessões e tokens
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="troque-por-uma-chave-forte-e-aleatoria"

# Ambiente: development, production
FLASK_ENV=development

# Banner modal convidando para /preview (true/false). Padrão: false (produção).
PREVIEW_DEMO_BANNER=false

# Badge fixo "PREVIEW v2" no canto da UI v2 (true/false). Padrão: false (produção).
PREVIEW_SHOW_BADGE=false

# Configuração do banco de dados
# DATABASE_URL deve ser a MESMA instância para:
#   - Flask (app.py / gunicorn)
#   - Jobs CLI (python -m jobs.prospeccao ...)
# Em deploy (Render/Railway), aponte Flask e workers/cron para o mesmo Postgres.
DATABASE_URL="sqlite:///tronik.db"

TRONIK_SEDE_LAT=
TRONIK_SEDE_LNG=
TRONIK_SEDE_LABEL=Sede Tronik

# CORS - Origens permitidas (separe por vírgula se mais de um)
# Em desenvolvimento, pode usar "*" mas em produção use domínios específicos
CORS_ORIGINS="http://localhost:5000,http://127.0.0.1:5000"

# Rate Limiting
RATELIMIT_ENABLED=true
# Em producao com varios workers/instancias use Redis:
# RATELIMIT_STORAGE_URL="redis://localhost:6379/0"
RATELIMIT_STORAGE_URL="memory://"

# --- Telemetria (ESP32 -> POST /api/sensor/telemetria) ---
# Opcional: um unico segredo para todos os dispositivos durante migracao (desligue depois).
# TELEMETRY_SHARED_SECRET=
# Em desenvolvimento, permite POST sem api_token no sensor se true:
TELEMETRIA_ALLOW_NO_TOKEN=true

# Configurações de segurança
SESSION_COOKIE_SECURE=false  # true em produção com HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE="Lax"

# Configurações de debug (apenas desenvolvimento)
DEBUG=false

# Configurações de logging
LOG_LEVEL=INFO

# ========================================
# USUÁRIO ADMINISTRADOR + LOGIN FIXO EM DESENVOLVIMENTO
# ========================================
#
# Produção ou ambientes não-dev: defina ADMIN_* para criar o primeiro admin se ainda não existir.
#
# Em FLASK_ENV=development, se você NÃO definir nenhuma variável ADMIN_*, o primeiro admin
# é criado automaticamente com os valores DEV_* abaixo (usuário dev, senha fixa para testes locais).
#
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Credenciais de desenvolvimento (usuário extra "dev" sempre que possível — ver código)
DEV_USERNAME=dev
DEV_EMAIL=dev@localhost.internal
DEV_PASSWORD=DevTronik!local

# Para repor a senha do utilizador DEV_USERNAME quando já existir na base:
# DEV_SYNC_PASSWORD=true

# Para desativar qualquer uso automático de DEV_* (primeiro admin sem ADMIN_* ou utilizador dev):
# DISABLE_DEV_CREDENTIALS=true

# IMPORTANTE: ADMIN_PASSWORD deve ter pelo menos 8 caracteres quando configurado explicitamente.

# Configurações de email (para notificações)
# Descomente e configure para habilitar notificações por email
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@tronik.com

# Configurações de agendamento automático
AGENDAMENTO_ENABLED=false
# Habilita processamento automático de alertas
# true = ativado, false = desativado

AGENDAMENTO_INTERVALO_MINUTOS=60
# Intervalo em minutos para processar alertas automaticamente
# Padrão: 60 minutos (1 hora)
# Mínimo recomendado: 15 minutos

# ========================================
# PIPELINE ML PROSPECÇÃO REE (Sócrates)
# ========================================
# Requer AGENDAMENTO_ENABLED=true para o scheduler APScheduler estar ativo.
PROSPECCAO_PIPELINE_ENABLED=false
# true = agenda ingest→normalize→link-crm→build-features→train→score (publicação via score-candidates)

PROSPECCAO_PIPELINE_INTERVAL_HOURS=168
# Intervalo entre execuções (padrão 168 = semanal)

PROSPECCAO_PIPELINE_VERSION=prospeccao-ree-v3.2
# Versão do schema/pipeline passada a build-features e train-ranker

PROSPECCAO_PIPELINE_USE_INTERNAL_LABELS=true
# Labels operacionais (parceiro/coleta/contrato) em build-features

PROSPECCAO_PIPELINE_SKIP_INGEST=false
# true = pula harvest no job agendado (útil se ingest roda em cron separado)

PROSPECCAO_PIPELINE_SKIP_NORMALIZE=false
# true = pula normalize no job agendado

PROSPECCAO_PIPELINE_INGEST_STEPS=ibge,geoportal,ckan_meta,pncp
# Passos do harvest quando ingest está habilitado

PROSPECCAO_PIPELINE_USE_PS1=false
# true (Windows): usa run_pipeline.ps1 com -SkipFetch -SkipCnefe -SkipReceita

PROSPECCAO_PIPELINE_BUILD_LIMIT=
# Limite opcional de empresas em build-features (smoke test, ex.: 100)

PROSPECCAO_PIPELINE_STEP_TIMEOUT_S=7200
# Timeout por passo CLI em segundos (padrão 2h)
