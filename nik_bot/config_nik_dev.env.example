# Config local de desenvolvimento da Nik
# Copie para `nik_bot/config_nik_dev.env` e ajuste os valores.

FLASK_ENV=development
SECRET_KEY=troque-esta-chave-por-uma-chave-com-32-caracteres-ou-mais
DATABASE_URL=sqlite:///tronik.db

# Login local de desenvolvimento
DEV_USERNAME=dev
DEV_EMAIL=dev@localhost.internal
DEV_PASSWORD=DevTronik!local

# Preview / scheduler
AGENDAMENTO_ENABLED=true
NIK_PRE_GERACAO_ENABLED=true
NIK_PRE_GERACAO_INTERVALO_MIN=60

# Nik
NIK_ENABLED=true
# Planejador de ferramentas: heuristic (padrão) | llm | auto (LLM com fallback heurístico)
NIK_AGENT_PLANNER=heuristic
# Loop tool-calling nativo (requer modelo com tools API)
NIK_AGENT_LOOP=false
NIK_MODELO_RESUMO=google/gemma-3-1b-it
# Provedor primario (ex.: Groq)
NVIDIA_API_KEY=
NIK_API_BASE_URL=https://api.groq.com/openai/v1
NIK_MODELO_OPS=google/gemma-3-27b-it
# Análise de imagem no chat Ops (Gemma 3 27B multimodal no NIM)
NIK_MULTIMODAL_ENABLED=false
NIK_MODELO_LANDING=mistralai/ministral-14b-instruct-2512
NIK_MODELO_FALLBACK=google/gemma-3-1b-it

# Se o primario falhar (429, timeout, etc.), tenta NVIDIA NIM (chave nvapi-)
NIK_PROVIDER_FALLBACK_ENABLED=true
NIK_API_FALLBACK_BASE_URL=https://integrate.api.nvidia.com/v1
NIK_API_FALLBACK_KEY=
# Groq rápido (sem Llama 70B): llama-3.1-8b-instant ou allam-2-7b
NIK_NVIDIA_MODELO_DEFAULT=llama-3.1-8b-instant

# Rede: timeouts, retries transitórios (nao aplica a 429 — evita piorar quota)
NIK_HTTP_TIMEOUT_S=120
NIK_NETWORK_RETRY_COUNT=2
NIK_NETWORK_RETRY_BACKOFF_MS=400
NIK_WEB_NETWORK_RETRIES=2
# Modelo que só redige a resposta após busca web (vazio = NIK_MODELO_ANALYTICS; evita 70B/TPD)
# NIK_MODELO_WEB_WRITER=
# Relatório narrativo pós-pesquisa web (tokens / tamanho do texto)
NIK_MAX_TOKENS_WEB_RELATORIO=1600
NIK_MAX_CHARS_WEB_RELATORIO=5200
NIK_TEMPERATURE_WEB_RELATORIO=0.45

NIK_CACHE_TTL_LANDING=3600
NIK_CACHE_TTL_RESUMO_OPS=1800
NIK_CACHE_TTL_COLETOR_OPS=600
NIK_CACHE_TTL_RELATORIO_OPS=3600

NIK_MAX_TOKENS_OPS=512
NIK_MAX_TOKENS_LANDING=384
NIK_TEMPERATURE_OPS=0.3
NIK_TEMPERATURE_LANDING=0.7

# NVIDIA Integrate / Nemotron (opcional): sem reasoning por defeito
NIK_NEMOTRON_REASONING_DISABLED=true
# NIK_NEMOTRON_EXTRA_BODY={"foo":1}

# Landing pública — blocos educativos: Nemotron (`mistralai/mistral-nemotron`) primeiro na Integrate; fallback = NIK_MODELO_LANDING (Groq)
NIK_LANDING_USE_NVIDIA=true
NIK_MODELO_LANDING_NVIDIA=mistralai/mistral-nemotron
