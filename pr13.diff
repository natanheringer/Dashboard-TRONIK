+{% extends 'preview/base_v2.html' %}
+{% set current = 'gestao' %}
+{% block title %}Gestão · Tronik{% endblock %}
+
+{% block head_extra %}
+<style>
+  .gestao-tabs {
+    display: flex;
+    gap: var(--space-2);
+    margin-bottom: var(--space-8);
+    border-bottom: 1px solid var(--line-default);
+    padding-bottom: var(--space-4);
+  }
+  
+  .gestao-tab {
+    padding: var(--space-2) var(--space-6);
+    background: transparent;
+    border: none;
+    font-family: var(--font-display);
+    font-size: var(--text-md);
+    font-weight: 500;
+    color: var(--ink-tertiary);
+    cursor: pointer;
+    border-radius: var(--radius-md);
+    transition: all 160ms ease;
+  }
+  
+  .gestao-tab:hover {
+    background: var(--tronik-ghost);
+    color: var(--tronik);
+  }
+  
+  .gestao-tab.active {
+    background: var(--tronik);
+    color: var(--paper-elevated);
+  }
+  
+  .tab-content {
+    display: none;
+    animation: fadeIn 200ms ease-out;
+  }
+  
+  .tab-content.active {
+    display: grid;
+    grid-template-columns: 1fr 380px;
+    gap: var(--space-8);
+  }
+  
+  @keyframes fadeIn {
+    from { opacity: 0; transform: translateY(8px); }
+    to { opacity: 1; transform: translateY(0); }
+  }
+  
+  .gestao-grid {
+    display: flex;
+    flex-direction: column;
+    gap: var(--space-6);
+  }
+  
+  .config-card {
+    background: var(--paper-card);
+    border: 1px solid var(--line-default);
+    border-radius: var(--radius-lg);
+    padding: var(--space-6);
+  }
+  
+  .config-card h2 {
+    font-family: var(--font-display);
+    font-size: var(--text-lg);
+    margin-bottom: var(--space-4);
+    color: var(--ink-primary);
+  }
+  
+  .form-grid-v2 {
+    display: grid;
+    grid-template-columns: 1fr 1fr;
+    gap: var(--space-4);
+  }
+  
+  .form-group-v2 {
+    display: flex;
+    flex-direction: column;
+    gap: var(--space-1);
+  }
+  
+  .form-group-v2 label {
+    font-size: var(--text-xs);
+    font-weight: 600;
+    text-transform: uppercase;
+    letter-spacing: 0.05em;
+    color: var(--ink-tertiary);
+  }
+  
+  .form-input-v2 {
+    background: var(--paper-sunk);
+    border: 1px solid var(--line-default);
+    padding: var(--space-2) var(--space-3);
+    border-radius: var(--radius-md);
+    color: var(--ink-primary);
+    font-size: var(--text-sm);
+    transition: all 160ms ease;
+  }
+  
+  .form-input-v2:focus {
+    outline: none;
+    border-color: var(--tronik);
+    background: var(--paper-elevated);
+    box-shadow: 0 0 0 3px var(--tronik-ghost);
+  }
+  
+  .gestao-list {
+    display: flex;
+    flex-direction: column;
+    gap: var(--space-2);
+  }
+  
+  .gestao-item {
+    display: flex;
+    align-items: center;
+    justify-content: space-between;
+    padding: var(--space-4);
+    background: var(--paper-card);
+    border: 1px solid var(--line-default);
+    border-radius: var(--radius-md);
+    transition: all 160ms ease;
+  }
+  
+  .gestao-item:hover {
+    border-color: var(--line-strong);
+    background: var(--paper-elevated);
+  }
+  
+  .gestao-item-info strong {
+    display: block;
+    font-size: var(--text-sm);
+    color: var(--ink-primary);
+  }
+  
+  .gestao-item-info span {
+    font-size: var(--text-xs);
+    color: var(--ink-tertiary);
+  }
+  
+  .btn-delete-v2 {
+    padding: var(--space-1) var(--space-3);
+    background: transparent;
+    border: 1px solid var(--signal-critical-soft);
+    color: var(--signal-critical);
+    border-radius: var(--radius-sm);
+    font-size: var(--text-xs);
+    font-weight: 600;
+    cursor: pointer;
+    transition: all 160ms ease;
+  }
+  
+  .btn-delete-v2:hover {
+    background: var(--signal-critical);
+    color: var(--paper-elevated);
+    border-color: var(--signal-critical);
+  }
+  
+  .form-status {
+    padding: var(--space-3);
+    border-radius: var(--radius-md);
+    font-size: var(--text-sm);
+    display: none;
+    margin-top: var(--space-4);
+  }
+  
+  .form-status.success { background: var(--signal-ok-soft); color: var(--signal-ok); border: 1px solid var(--signal-ok); display: block; }
+  .form-status.error { background: var(--signal-critical-soft); color: var(--signal-critical); border: 1px solid var(--signal-critical); display: block; }
+
+  @media (max-width: 1024px) {
+    .tab-content.active {
+      grid-template-columns: 1fr;
+    }
+    .side-panel-gestao {
+      order: -1;
+    }
+  }
+</style>
+{% endblock %}
+
+{% block conteudo %}
+<div class="page-header">
+  <div class="page-title-group">
+    <h1>Gestão</h1>
+    <p>Operações de sistema e cadastro de coletores</p>
+  </div>
+</div>
+
+<div class="gestao-tabs">
+  <button class="gestao-tab active" data-tab="coletores">Coletores</button>
+  <button class="gestao-tab" data-tab="sensores">Sensores</button>
+  <button class="gestao-tab" data-tab="coletas">Coletas</button>
+</div>
+
+<!-- ABA COLETORES -->
+<div id="tab-coletores" class="tab-content active">
+  <section class="gestao-grid">
+    <div class="config-card">
+      <h2>Coletores Cadastrados</h2>
+      <div id="lista-coletores" class="gestao-list">
+        <p class="home-subtitle">Carregando lista...</p>
+      </div>
+    </div>
+  </section>
+  
+  <aside class="side-panel-gestao">
+    <div class="config-card">
+      <h2>Novo Coletor</h2>
+      <form id="form-novo-coletor">
+        <div style="display:flex; flex-direction:column; gap:var(--space-4);">
+          <div class="form-group-v2">
+            <label for="localizacao">Localização *</label>
+            <input type="text" id="localizacao" name="localizacao" class="form-input-v2" required placeholder="Ex: Asa Norte - Bloco A">
+          </div>
+          
+          <div class="form-grid-v2">
+            <div class="form-group-v2">
+              <label for="tipo_material_id">Material</label>
+              <select id="tipo_material_id" name="tipo_material_id" class="form-input-v2">
+                <option value="">Selecione...</option>
+              </select>
+            </div>
+            <div class="form-group-v2">
+              <label for="parceiro_id">Parceiro</label>
+              <select id="parceiro_id" name="parceiro_id" class="form-input-v2">
+                <option value="">Selecione...</option>
+              </select>
+            </div>
+          </div>
+          
+          <div class="form-grid-v2">
+            <div class="form-group-v2">
+              <label for="nivel_preenchimento">Nível (%)</label>
